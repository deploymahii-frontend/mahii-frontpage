# Firebase Configuration Template
# Copy this file and update with your Firebase project credentials
# Then save as .env in the client folder

# Get these values from: https://console.firebase.google.com/project/{YOUR_PROJECT}/settings/general

# Firebase API Key
# Location: Project Settings → General → Your apps → Web app → config
REACT_APP_FIREBASE_API_KEY=

# Firebase Auth Domain
# Format: {PROJECT_ID}.firebaseapp.com
# Example: my-project.firebaseapp.com
REACT_APP_FIREBASE_AUTH_DOMAIN=

# Firebase Database URL (Realtime Database)
# Format: https://{PROJECT_ID}-default-rtdb.{REGION}.firebasedatabase.app
# Example: https://my-project-default-rtdb.asia-southeast1.firebasedatabase.app/
REACT_APP_FIREBASE_DATABASE_URL=

# Firebase Project ID
# Same as the PROJECT_ID in URLs above
REACT_APP_FIREBASE_PROJECT_ID=

# Firebase Storage Bucket
# Format: {PROJECT_ID}.firebasestorage.app
# Example: my-project.firebasestorage.app
REACT_APP_FIREBASE_STORAGE_BUCKET=

# Firebase Messaging Sender ID
# Location: Project Settings → General → Your apps → Web app → config
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=

# Firebase App ID
# Location: Project Settings → General → Your apps → Web app → config
REACT_APP_FIREBASE_APP_ID=

# Backend API URL
REACT_APP_API_URL=http://localhost:5000/api

# Enable source maps for development (set to false for production)
GENERATE_SOURCEMAP=false
